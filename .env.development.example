# Copy to `.env.development` for local development (see `just init-env-dev`). Not committed.

# General
LOG_LEVEL=INFO
# Hostnames for Traefik (docker-compose.traefik.yml): http://${DOMAIN}, http://backend.${DOMAIN}, etc.
DOMAIN=myproject.localhost

# Traefik Docker provider: network services attach to for routing (see docker-compose.traefik.yml labels).
TRAEFIK_DOCKER_NETWORK=traefik-public

# Authentication
SECRET_KEY=secret_key

# First superuser (email + password). Created on backend prestart if missing.
FIRST_SUPERUSER_USERNAME=admin
FIRST_SUPERUSER_PASSWORD=admin

# From your machine use localhost:POSTGRES_PORT; containers override POSTGRES_PORT to 5432 for db.
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=myproject
POSTGRES_SCHEMA=public
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin

# MinIO (S3 API). From containers use http://storage:9000; from the host use http://localhost:9000.
BUCKET_URL=http://storage:9000
BUCKET_NAME=myproject
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin
S3_ACCESS_KEY_ID=admin
S3_SECRET_ACCESS_KEY=admin
