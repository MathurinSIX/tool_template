          "rawQuery": true,
          "rawSql": "WITH buckets AS (\n  SELECT generate_series($__timeFrom()::timestamptz, $__timeTo()::timestamptz, '10s'::interval) AS bucket_start\n),\nintervals AS (\n  SELECT\n    buckets.bucket_start AS ts,\n    COUNT(ts) AS nb_probes\n  FROM buckets\n  LEFT JOIN __POSTGRES_SCHEMA__.app_liveness ON ts > buckets.bucket_start AND ts <= buckets.bucket_start + interval '10s' \n  GROUP BY 1\n),\nbucket_availability AS (\n  SELECT\n    $__timeGroup(ts, $__interval) AS bucket_start,\n    AVG(\n      CASE\n        WHEN nb_probes > 0 THEN 100\n        ELSE 0\n      END\n    ) AS availability\n  FROM intervals\n  GROUP BY 1\n)\n\nSELECT\n  to_timestamp(bucket_start) AS \"From\",\n  to_timestamp(bucket_start) + make_interval(secs => $__interval_ms / 1000) AS \"To\",\n  availability AS \"Availability\",\n  STRING_AGG(name, E'\\n') AS steps\nFROM bucket_availability\nLEFT JOIN __POSTGRES_SCHEMA__.run_step ON updated_ts > to_timestamp(bucket_start) AND created_ts <= to_timestamp(bucket_start) + make_interval(secs => $__interval_ms / 1000)\nGROUP BY 1, 2, 3",
