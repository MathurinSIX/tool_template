          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH buckets AS (\n  SELECT generate_series($__timeFrom()::timestamptz,$__timeTo()::timestamptz, '10s'::interval) AS bucket_start\n),\nintervals AS (\n  SELECT\n    buckets.bucket_start AS ts,\n    COUNT(ts) AS nb_probes\n  FROM buckets\n  LEFT JOIN __POSTGRES_SCHEMA__.app_liveness ON ts > buckets.bucket_start AND ts <= buckets.bucket_start + interval '10s' \n  GROUP BY 1\n)\n\nSELECT\n  $__timeGroup(ts, $__interval) AS time,\n  AVG(\n    CASE\n      WHEN nb_probes > 0 THEN 100\n      ELSE 0\n    END\n  ) AS \"Availability\"\nFROM intervals\nGROUP BY 1\nORDER BY 1;",
          "refId": "A",
          "sql": {
