{
	"name": "frontend",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite --host 0.0.0.0 --port 3000",
		"build": "vite build",
		"preview": "vite preview --host 0.0.0.0 --port 3000",
		"start": "serve -s dist -l 3000",
